#!/usr/bin/env bash
# test stub for `copilot`: capture the resolved launch (model from --model, caps from env, flags from argv).
model=""; prev=""; sep=no
for a in "$@"; do
    [[ "$prev" == "--model" ]] && model="$a"
    [[ "$a" == "--" ]] && sep=yes
    prev="$a"
done
imagegen=on
[[ "$*" == *"--disable-mcp-server imagegen-mcp"* ]] && imagegen=off
office=no
[[ -n "${COPILOT_CUSTOM_INSTRUCTIONS_DIRS:-}" ]] && office=yes
echo "CAPTURE model=${model} base=${COPILOT_PROVIDER_BASE_URL:-} prompt=${COPILOT_PROVIDER_MAX_PROMPT_TOKENS:-} out=${COPILOT_PROVIDER_MAX_OUTPUT_TOKENS:-} imagegen=${imagegen} office=${office}"
echo "IMAGEGEN_HOST=${COPILOT_MCP_IMAGEGEN_HOST:-}"
echo "ARGV_HAS_SEP=${sep}"
exit 0
