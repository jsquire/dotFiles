{
  "_comment": "Local Ollama launcher roster. This repo copy is the canonical 5090-tier default and doubles as the template. Windows ships it verbatim; the CachyOS installer deploys it to ~/.config/local-llm/local-models.json and (for a 4090 install) overwrites 'tier' + 'registry' + 'task_alias' with the 4090 values. Read by copilot-local and crush-task to build the pickers. REPLACES the old ollama-tier.sh. Sections: registry (alias -> {label, ctx}, tier-dependent), task_alias (menu slot -> alias, tier-dependent), launchers.<name>.production/experimental (static menus: ordered categories of rows). A row's detail column defaults to task_alias[slot] plus any 'note'; set 'detail' to override. Row flags: office (inject office skill), imagegen (keep imagegen-mcp enabled). Crush rows also carry 'profile' (crush task: coding/review/docs/image).",
  "schema_version": 1,
  "tier": "5090",

  "registry": {
    "qwen36-27b-212k":       { "label": "Qwen3.6 27B (+MTP)",                 "ctx": 217088 },
    "qwen36-35b-256k":       { "label": "Qwen3.6 35B-A3B",                     "ctx": 262144 },
    "gemma4-31b-128k":       { "label": "Gemma 4 31B",                        "ctx": 131072 },
    "qwen3coder-144k":       { "label": "Qwen3-Coder 30B-A3B",                "ctx": 147456 },
    "glm47-flash-198k":      { "label": "GLM-4.7-Flash",                       "ctx": 202752 },
    "qwen3:8b":              { "label": "Qwen3 8B",                            "ctx": 40960  },
    "northmini-code-256k":   { "label": "North Mini Code 1.0",                "ctx": 262144 },
    "nemotron3-nano-256k":   { "label": "Nemotron 3 Nano 30B-A3B",            "ctx": 262144 },
    "ornith-35b-256k":       { "label": "Ornith-1.0-35B",                     "ctx": 262144 },
    "devstral2-24b-128k":    { "label": "Devstral Small 2 (24B)",             "ctx": 131072 }
  },

  "task_alias": {
    "heavy":     "qwen36-27b-212k",
    "coder":     "qwen3coder-144k",
    "review":    "qwen3coder-144k",
    "agentic":   "glm47-flash-198k",
    "image_llm": "qwen3:8b",
    "h1": "qwen36-27b-212k",
    "h2": "qwen36-35b-256k",
    "h3": "gemma4-31b-128k",
    "h4": "qwen3coder-144k",
    "h5": "glm47-flash-198k",
    "h6": "northmini-code-256k",
    "h7": "nemotron3-nano-256k",
    "h8": "ornith-35b-256k",
    "h9": "devstral2-24b-128k"
  },

  "launchers": {
    "copilot": {
      "production": {
        "categories": [
          {
            "heading": "Coding",
            "rows": [
              { "key": "1", "label": "Heavy coding", "slot": "heavy" },
              { "key": "2", "label": "Light coding", "slot": "coder" },
              { "key": "3", "label": "Code review",  "slot": "review" }
            ]
          },
          {
            "heading": "Writing & Documents",
            "rows": [
              { "key": "4", "label": "Technical docs",   "slot": "heavy" },
              { "key": "5", "label": "Creative writing", "slot": "heavy" },
              { "key": "6", "label": "Office documents", "slot": "agentic", "office": true }
            ]
          },
          {
            "heading": "Visual",
            "rows": [
              { "key": "7", "label": "Image generation", "slot": "image_llm", "note": "+ HiDream (MCP)", "imagegen": true }
            ]
          }
        ]
      },
      "experimental": {
        "categories": [
          {
            "heading": "Heavy-coding bench",
            "subtitle": "(VRAM-resident; swap model, MCP off)",
            "rows": [
              { "key": "1", "label": "Qwen3.6 27B+MTP",      "slot": "h1" },
              { "key": "2", "label": "Qwen3.6 35B-A3B MoE",  "slot": "h2" },
              { "key": "3", "label": "Gemma 4 31B dense",    "slot": "h3" },
              { "key": "4", "label": "Qwen3-Coder 30B-A3B",  "slot": "h4" },
              { "key": "5", "label": "GLM-4.7-Flash",        "slot": "h5" },
              { "key": "6", "label": "North Mini Code 1.0",  "slot": "h6" },
              { "key": "7", "label": "Nemotron 3 Nano 30B",  "slot": "h7" },
              { "key": "8", "label": "Ornith-1.0-35B",       "slot": "h8" },
              { "key": "9", "label": "Devstral Small 2 24B", "slot": "h9" }
            ]
          }
        ]
      }
    },

    "crush": {
      "production": {
        "categories": [
          {
            "heading": "Coding",
            "rows": [
              { "key": "1", "label": "Heavy coding", "slot": "heavy",  "profile": "coding" },
              { "key": "2", "label": "Light coding", "slot": "coder",  "profile": "coding" },
              { "key": "3", "label": "Code review",  "slot": "review", "profile": "review" }
            ]
          },
          {
            "heading": "Writing & Documents",
            "rows": [
              { "key": "4", "label": "Documents", "slot": "agentic", "profile": "docs", "note": "+ office skill" }
            ]
          },
          {
            "heading": "Visual",
            "rows": [
              { "key": "5", "label": "Image generation", "slot": "image_llm", "profile": "image", "note": "+ HiDream (MCP)" }
            ]
          }
        ]
      },
      "experimental": {
        "categories": [
          {
            "heading": "Heavy-coding bench",
            "subtitle": "(coding profile, swap model)",
            "rows": [
              { "key": "1", "label": "Qwen3.6 27B dense",    "slot": "h1", "profile": "coding" },
              { "key": "2", "label": "Qwen3.6 35B-A3B MoE",  "slot": "h2", "profile": "coding" },
              { "key": "3", "label": "Gemma 4 31B dense",    "slot": "h3", "profile": "coding" },
              { "key": "4", "label": "Qwen3-Coder 30B-A3B",  "slot": "h4", "profile": "coding" },
              { "key": "5", "label": "GLM-4.7-Flash",        "slot": "h5", "profile": "coding" },
              { "key": "6", "label": "North Mini Code 1.0",  "slot": "h6", "profile": "coding" },
              { "key": "7", "label": "Nemotron 3 Nano 30B",  "slot": "h7", "profile": "coding" },
              { "key": "8", "label": "Ornith-1.0-35B",       "slot": "h8", "profile": "coding" },
              { "key": "9", "label": "Devstral Small 2 24B", "slot": "h9", "profile": "coding" }
            ]
          }
        ]
      }
    }
  }
}
