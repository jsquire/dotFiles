{
    "$schema": "https://crush.charm.sh/schema/mcp-servers.json",
    "servers": {
        "word-mcp": {
            "command": "uv",
            "args": ["run", "--directory", "{{LOCALAPPDATA}}/ai-tools/mcp-word", "word_mcp_server"],
            "description": "Word document creation and automation",
            "enabled": true
        },
        "pptx-mcp": {
            "command": "uv",
            "args": ["run", "--directory", "{{LOCALAPPDATA}}/ai-tools/mcp-pptx", "ppt_mcp_server"],
            "description": "PowerPoint presentation creation",
            "enabled": true
        }
    }
}
