  "models": {
    "large": {
      "model": "qwen36-128k",
      "provider": "ollama",
      "max_tokens": 32000
    },
    "small": {
      "model": "qwen3:14b",
      "provider": "ollama",
      "max_tokens": 8000
    }
  },
  "mcp": {
    "word-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": ["--python", "3.12", "docx-mcp-server"],
      "disabled": true
    },
    "pptx-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": ["ppt-mcp"],
      "disabled": true
    },
    "pptx-mcp-xplat": {
      "type": "stdio",
      "command": "uvx",
      "args": ["--python", "3.12", "office-powerpoint-mcp-server"],
      "disabled": true
    },
    "imagegen-mcp": {
      "type": "stdio",
      "command": "__LOCALAPPDATA__/ai-tools/mcp-imagegen/__VENV_BIN__/python__EXE__",
      "args": ["__LOCALAPPDATA__/ai-tools/mcp-imagegen/imagegen-mcp-server.py"],
      "env": {
        "IMAGEGEN_URL": "http://__IMAGEGEN_HOST__:8001"
      },
      "disabled": true
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__git__(add|commit|push|merge|rebase|reset|stash|checkout_branch|delete_branch|tag|cherry_pick|revert)",
        "command": "python__EXE_SUFFIX__ -c \"import sys; print('Git write operations are blocked by policy.'); sys.exit(2)\"",
        "timeout": 5
      }
    ]
  },
  "lsp": {
    "csharp-ls": {
      "command": "csharp-ls",
      "filetypes": ["cs", "csx"],
      "root_markers": ["*.sln", "*.csproj", ".git"]
    }
  }
}