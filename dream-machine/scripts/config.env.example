# dream-machine / AdGuard failover configuration
#
# Copy this file to config.env and edit for your environment.
# It is sourced by both the installer (on the workstation) and by
# health-check.sh (on the UDM after deployment).
#
# All variables use POSIX shell syntax; no spaces around '='.

# ------------------------------------------------------------------
# UDM / SSH — used only by install.sh and the verify/uninstall scripts
# ------------------------------------------------------------------

# Hostname or IP of the UDM SE, reachable over SSH from the workstation.
UDM_HOST="192.168.1.1"

# SSH user on the UDM (root on stock UniFi OS).
UDM_SSH_USER="root"

# ------------------------------------------------------------------
# AdGuard Home — the primary DNS resolver
# ------------------------------------------------------------------

# IP address of your AdGuard Home instance. This is the value that will
# be handed out via DHCP and that clients will use as their DNS server.
ADGUARD_IP="192.168.1.99"

# ------------------------------------------------------------------
# Health-check probe
# ------------------------------------------------------------------

# Domain name resolved against AdGuard to test liveness. Should be a name
# AdGuard will not block. Default (dns.quad9.net) doubles as a sanity
# check for upstream reachability.
PROBE_NAME="dns.quad9.net"

# Seconds between probes while in the current state.
INTERVAL=10

# Consecutive failed probes required to declare AdGuard DOWN and engage
# failover. Higher values = more tolerant of transient blips.
FAIL_THRESHOLD=3

# Consecutive successful probes required to declare AdGuard UP again and
# revert failover.
RECOVER_THRESHOLD=2

# ------------------------------------------------------------------
# Fallback resolvers — Quad9 by default (malware-blocking, no-log)
# ------------------------------------------------------------------

# Primary fallback IP. DNAT rules will redirect traffic here when
# AdGuard is DOWN.
FALLBACK_PRIMARY="9.9.9.9"

# Secondary fallback (used only if a future enhancement adds a
# second-level probe of the primary fallback; not required today).
FALLBACK_SECONDARY="149.112.112.112"

# ------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------

# Where the daemon writes its log on the UDM. /data survives firmware
# updates; /var/log does not.
LOG_FILE="/data/adguard-failover.log"

# Rotate (truncate) the log when it exceeds this many bytes.
LOG_MAX_BYTES=5242880
